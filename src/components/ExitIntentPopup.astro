---
// ExitIntentPopup.astro
---

<div class="exit-intent-backdrop" id="exit-intent-backdrop" aria-hidden="true" role="dialog">
  <div class="exit-intent-modal" style="background: white; max-width: 520px; width: 90%; border-radius: var(--radius-md); overflow: hidden; position: relative; box-shadow: var(--shadow-lg); border: 1px solid var(--border-color); transform: scale(0.9); transition: transform 0.3s ease;">
    <!-- Top colored decorative bar -->
    <div class="modal-stripe" style="height: 6px; background: linear-gradient(90deg, var(--secondary) 0%, var(--accent) 100%);"></div>
    
    <!-- Close Button -->
    <button class="close-modal-btn" id="close-modal-btn" aria-label="Fermer la fenêtre" style="position: absolute; top: 15px; right: 20px; background: none; border: none; font-size: 28px; color: var(--text-muted); cursor: pointer; line-height: 1; z-index: 10;">&times;</button>
    
    <!-- Content -->
    <div class="modal-body" style="padding: 40px 30px 30px; text-align: center;">
      <div class="modal-icon" style="font-size: 48px; margin-bottom: 15px; display: inline-block;">🏗️</div>
      <h3 style="font-size: 22px; margin-bottom: 12px; color: var(--primary); font-family: var(--font-heading);">Attendez ! Évitez les fuites et sécurisez votre toiture face à l'hiver...</h3>
      <p class="modal-desc" style="font-size: 14.5px; color: var(--text-muted); line-height: 1.5; margin-bottom: 25px;">
        Dans le Rhône (69), le gel, la neige et les intempéries endommagent rapidement les toits mal isolés ou vieillissants. Comparez les artisans couvreurs certifiés RGE de votre secteur pour sécuriser votre couverture.
      </p>
      
      <!-- Bullet Points -->
      <ul class="modal-bullets" style="list-style: none; padding: 0; text-align: left; display: flex; flex-direction: column; gap: 12px; margin-bottom: 30px;">
        <li style="display: flex; gap: 10px; font-size: 13.5px; color: var(--text);">
          <span class="bullet-check" style="color: var(--secondary); font-weight: bold;">✓</span>
          <span><strong>TVA réduite à 5,5% ou 10% :</strong> Applicable sur les travaux de couverture et d'isolation énergétique.</span>
        </li>
        <li style="display: flex; gap: 10px; font-size: 13.5px; color: var(--text);">
          <span class="bullet-check" style="color: var(--secondary); font-weight: bold;">✓</span>
          <span><strong>Aides Éco-Rénov &amp; ANAH :</strong> MaPrimeRénov' finance l'isolation sarking de votre toiture dans la métropole lyonnaise.</span>
        </li>
        <li style="display: flex; gap: 10px; font-size: 13.5px; color: var(--text);">
          <span class="bullet-check" style="color: var(--secondary); font-weight: bold;">✓</span>
          <span><strong>Garantie Décennale incluse :</strong> Comparez gratuitement 3 artisans locaux sans aucun engagement.</span>
        </li>
      </ul>
      
      <!-- CTA Buttons -->
      <div class="modal-actions" style="display: flex; flex-direction: column; gap: 12px;">
        <button class="btn-primary pulse-btn" id="exit-popup-cta" style="padding: 14px 20px; border-radius: var(--radius-sm); font-weight: bold; border: none; cursor: pointer; color: white;">
          📋 Comparer les devis toiture gratuits &rarr;
        </button>
        <button class="opt-out-btn" id="exit-popup-opt-out" style="background: none; border: none; font-size: 11px; color: var(--text-muted); cursor: pointer; text-decoration: underline; line-height: 1.4;">
          Non merci, je préfère prendre le risque de fuite d'eau au prochain hiver rhodanien
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .exit-intent-backdrop {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(28, 25, 23, 0.4);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .exit-intent-backdrop.show {
    display: flex;
    opacity: 1;
  }
  .exit-intent-backdrop.show .exit-intent-modal {
    transform: scale(1) !important;
  }
  .close-modal-btn:hover {
    color: var(--text) !important;
  }
  .opt-out-btn:hover {
    color: var(--text) !important;
  }

  /* Pulsing button effect */
  .pulse-btn {
    animation: pulseGlow 2.5s infinite;
  }

  @keyframes pulseGlow {
    0% {
      box-shadow: 0 0 0 0 rgba(71, 85, 105, 0.4);
    }
    70% {
      box-shadow: 0 0 0 10px rgba(71, 85, 105, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(71, 85, 105, 0);
    }
  }

  /* Global pulse highlight for lead forms on CTA click */
  :global(.pulse-form) {
    animation: formPulseGlow 1s ease-in-out infinite alternate !important;
    transition: all 0.3s ease !important;
  }

  @keyframes formPulseGlow {
    from {
      box-shadow: var(--shadow-lg), 0 0 0 0px rgba(28, 25, 23, 0.4) !important;
      border-color: var(--border-color) !important;
    }
    to {
      box-shadow: var(--shadow-lg), 0 0 0 10px rgba(28, 25, 23, 0.25) !important;
      border-color: var(--primary) !important;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const backdrop = document.getElementById('exit-intent-backdrop');
    const closeBtn = document.getElementById('close-modal-btn');
    const ctaBtn = document.getElementById('exit-popup-cta');
    const optOutBtn = document.getElementById('exit-popup-opt-out');

    if (!backdrop) return;

    // localStorage key
    const isShownKey = 'toiture_exit_popup_shown_69';
    if (localStorage.getItem(isShownKey) === 'true') return;

    let alreadyShown = false;

    const showModal = () => {
      if (alreadyShown) return;
      alreadyShown = true;
      localStorage.setItem(isShownKey, 'true');
      backdrop.style.display = 'flex';
      void backdrop.offsetWidth;
      backdrop.classList.add('show');
      document.removeEventListener('mouseleave', handleMouseLeave);
    };

    const closeModal = () => {
      backdrop.classList.remove('show');
      setTimeout(() => {
        backdrop.style.display = 'none';
      }, 300);
    };

    const handleMouseLeave = (e: MouseEvent) => {
      if (e.clientY < 20) {
        showModal();
      }
    };
    document.addEventListener('mouseleave', handleMouseLeave);

    // Close handlers
    closeBtn?.addEventListener('click', closeModal);
    optOutBtn?.addEventListener('click', closeModal);

    backdrop.addEventListener('click', (e) => {
      if (e.target === backdrop) closeModal();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && backdrop.classList.contains('show')) closeModal();
    });

    // CTA: scroll to form
    ctaBtn?.addEventListener('click', () => {
      closeModal();
      const targetForm = document.getElementById('devis') || document.getElementById('borne-lead-form');
      if (targetForm) {
        targetForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
        targetForm.classList.add('pulse-form');
        setTimeout(() => targetForm.classList.remove('pulse-form'), 3000);
        const firstBox = targetForm.querySelector('.option-box') as HTMLElement;
        if (firstBox) {
          firstBox.focus();
          firstBox.style.outline = '3px solid var(--secondary)';
          setTimeout(() => { if (firstBox) firstBox.style.outline = ''; }, 3000);
        }
      } else {
        window.location.href = '/devis/';
      }
    });
  });
</script>
