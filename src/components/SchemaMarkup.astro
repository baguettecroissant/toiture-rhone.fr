---
import config from '../data/config.json';

interface FAQItem {
  question: string;
  answer: string;
}

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  pageUrl: string;
  pageTitle: string;
  pageDescription: string;
  faqItems?: FAQItem[];
  breadcrumbItems?: BreadcrumbItem[];
  communeName?: string;
}

const { pageUrl, pageTitle, pageDescription, faqItems, breadcrumbItems, communeName } = Astro.props;

const siteUrl = `https://${config.domain}`;

// LocalBusiness schema
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": config.brandName,
  "description": config.description,
  "url": siteUrl,
  "areaServed": {
    "@type": "AdministrativeArea",
    "name": `${config.department} (${config.departmentCode})`
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": config.mainCity,
    "addressRegion": "Auvergne-Rhône-Alpes",
    "addressCountry": "FR"
  },
  "priceRange": "€€",
  ...(communeName && {
    "serviceArea": {
      "@type": "City",
      "name": communeName
    }
  })
};

// FAQ schema
const faqSchema = faqItems && faqItems.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
} : null;

// BreadcrumbList schema
const breadcrumbSchema = breadcrumbItems && breadcrumbItems.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.label,
    ...(item.href && { "item": `${siteUrl}${item.href}` })
  }))
} : null;

// WebPage schema
const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": pageTitle,
  "description": pageDescription,
  "url": pageUrl,
  "dateModified": "2026-06-22",
  "isPartOf": {
    "@type": "WebSite",
    "name": config.brandName,
    "url": siteUrl
  }
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
<script is:inline type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
{faqSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
{breadcrumbSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
