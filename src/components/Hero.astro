---
import StepsForm from './StepsForm.astro';
import config from '../data/config.json';
---

<section class="hero">
  <div class="container hero-inner">
    <!-- Left text content -->
    <div class="hero-content">
      <div class="hero-badge">
        🏗️ Spécialiste zinc &amp; ardoise depuis 2008
      </div>
      
      <h1 style="min-height: 110px;">
        Toiture dans le Rhône (69) — <span id="typewriter-text" style="color: #ef4444; border-right: 2px solid #ef4444; padding-right: 4px;"></span>
      </h1>
      
      <p style="margin-top: 15px; margin-bottom: 20px;">
        Savoir-faire artisanal et solidité face aux éléments. Sécurisez votre maison, villa ou copropriété haussmannienne face aux hivers froids, à la neige et aux tempêtes rhodaniennes. Obtenez vos devis et comparez gratuitement 3 couvreurs RGE locaux certifiés.
      </p>

      <!-- Animated counter of roofs renovated -->
      <div style="background: rgba(28, 25, 23, 0.45); border: 1.5px solid var(--border-color); border-radius: var(--radius-md); padding: 15px 20px; display: inline-flex; align-items: center; gap: 15px; margin-bottom: 25px;">
        <span style="font-family: var(--font-mono); font-size: 38px; font-weight: 900; color: #ef4444; line-height: 1; display: inline-block; min-width: 90px; text-align: right;" id="roofs-saved-val">
          0+
        </span>
        <div style="font-size: 13.5px; line-height: 1.3;">
          <strong style="color: white; display: block;">Toitures Rénovées dans le Rhône</strong>
          <span style="color: var(--primary-light);">Artisans locaux qualifiés Qualibat et certifiés RGE</span>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; margin-top: 10px; color: white;">
        <div style="display: flex; align-items: center; gap: 8px; font-size: 14.5px;">
          <span style="color: #ef4444; font-weight: bold; font-size: 18px;">✓</span> Couvreurs RGE &amp; Qualibat
        </div>
        <div style="display: flex; align-items: center; gap: 8px; font-size: 14.5px;">
          <span style="color: #ef4444; font-weight: bold; font-size: 18px;">✓</span> Garantie Décennale 10 ans
        </div>
        <div style="display: flex; align-items: center; gap: 8px; font-size: 14.5px;">
          <span style="color: #ef4444; font-weight: bold; font-size: 18px;">✓</span> Devis Gratuit sous 24h
        </div>
        <div style="display: flex; align-items: center; gap: 8px; font-size: 14.5px;">
          <span style="color: #ef4444; font-weight: bold; font-size: 18px;">✓</span> Isolation Sarking Éligible Aides
        </div>
      </div>
      
      <!-- Visual hero image slot -->
      <div style="margin-top: 35px;" class="hero-image-container">
        <img 
          src="/images/hero-toiture-rhone.png" 
          alt="Classic Lyon haussmannian building with freshly renovated zinc roof, grey-blue winter sky, Fourvière basilica in background, rooftop chimneys, professional photography, no text, no people, urban architectural style" 
          class="hero-img"
          loading="eager"
        />
      </div>
    </div>

    <!-- Right steps form -->
    <div class="hero-right">
      <StepsForm />
    </div>
  </div>
</section>

<script is:inline>
  // Typewriter effect
  document.addEventListener('DOMContentLoaded', () => {
    const txtEl = document.getElementById('typewriter-text');
    if (!txtEl) return;

    const words = [
      "Artisans Couvreurs du Rhône",
      "Toitures Zinc à Joint Debout",
      "Rénovation Tuile & Ardoise",
      "Dépannage Fuite sous 24h",
      "Isolation Thermique Sarking"
    ];
    
    let wordIndex = 0;
    let charIndex = 0;
    let isDeleting = false;
    
    const type = () => {
      const currentWord = words[wordIndex];
      if (isDeleting) {
        txtEl.textContent = currentWord.substring(0, charIndex - 1);
        charIndex--;
      } else {
        txtEl.textContent = currentWord.substring(0, charIndex + 1);
        charIndex++;
      }
      
      let speed = isDeleting ? 40 : 80;
      
      if (!isDeleting && charIndex === currentWord.length) {
        // Pause at the end of the word
        speed = 2000;
        isDeleting = true;
      } else if (isDeleting && charIndex === 0) {
        isDeleting = false;
        wordIndex = (wordIndex + 1) % words.length;
        speed = 500;
      }
      
      setTimeout(type, speed);
    };
    
    type();
  });

  // Animated counter for renovated roofs (up to 480)
  document.addEventListener('DOMContentLoaded', () => {
    const counterEl = document.getElementById('roofs-saved-val');
    if (!counterEl) return;
    
    let currentVal = 0;
    const targetVal = 480; // renovated roofs count
    const duration = 2000; // 2 seconds
    const intervalTime = 30; // 30ms
    const totalSteps = duration / intervalTime;
    const stepSize = targetVal / totalSteps;
    
    const timer = setInterval(() => {
      currentVal += stepSize;
      if (currentVal >= targetVal) {
        currentVal = targetVal;
        clearInterval(timer);
      }
      counterEl.textContent = `${Math.round(currentVal)}+`;
    }, intervalTime);
  });
</script>
